# MediURG — variables d'environnement (exemple).
# Copier les clés utiles dans .env.local (gitignoré) pour le dev local,
# et les renseigner dans le dashboard Vercel pour la prod.

# ── Auth Supabase (optionnel, feature flag AUTH_ENABLED) ──────────────
# Préfixe VITE_ = exposé au client (clé publique seulement, jamais service_role).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Fallback legacy accepté si le projet n'a pas encore de publishable key :
# VITE_SUPABASE_ANON_KEY=
VITE_ADMIN_EMAILS=

# ── Notifications PWA internes des demandes d'accès ──────────────────
# PAS de préfixe VITE_ : ces valeurs restent côté serveur.
# Générer une paire VAPID une seule fois :
# node -e "import('web-push').then(w=>console.log(w.default.generateVAPIDKeys()))"
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.com
# Préfixe VITE_ = clé publique exposée au navigateur, normal pour Web Push.
VITE_WEB_PUSH_PUBLIC_KEY=
# Clé secrète Supabase service_role, serveur uniquement, pour lire les
# abonnements push des admins actifs et purger les endpoints expirés.
SUPABASE_SERVICE_ROLE_KEY=
# URL publique de l'app, utilisée quand tu touches la notification.
APP_PUBLIC_URL=
VITE_TUTORAT_URL=

# ── Analyse ECG par IA — /api/analyze-ecg (proxy serverless) ──────────
# PAS de préfixe VITE_ : ces clés restent côté serveur (jamais bundlées,
# jamais visibles dans le navigateur). Au moins l'une des deux suffit.
#
# Stratégie : Gemini en principal, repli automatique sur Mistral si le
# quota gratuit Gemini est atteint ou en cas d'erreur.
#
# 1) GEMINI_API_KEY (recommandé, gratuit) :
#    https://aistudio.google.com/apikey  → « Create API key » → coller ici.
#    Offre gratuite : ~15 req/min, 1500/jour (large pour un usage solo).
GEMINI_API_KEY=
#
# 2) MISTRAL_API_KEY (repli, gratuit) :
#    https://console.mistral.ai/  → API Keys → plan « Experiment » gratuit.
MISTRAL_API_KEY=
