{
  "name": "mediurg",
  "version": "1.0.0",
  "description": "Application PWA hors ligne de pharmacologie d'urgence pour SAUV, SMUR et SAU",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@supabase/supabase-js": "^2.105.4",
    "html-to-image": "^1.11.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.1.1"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "node scripts/check-versions.cjs && vite build",
    "analyze": "cross-env ANALYZE=true vite build && echo Open build/stats.html",
    "preview": "vite preview",
    "check-versions": "node scripts/check-versions.cjs",
    "lint": "eslint src",
    "lint:fast": "oxlint src",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css}\" \"*.{js,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css}\" \"*.{js,json,html}\"",
    "verify": "npm run typecheck && npm run lint && npm run knip && npm test",
    "test": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest",
    "test:coverage": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest run --coverage",
    "generate-pwa-assets": "pwa-assets-generator",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint",
      "prettier --write"
    ],
    "*.{css,html,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "axe-core": "^4.11.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "knip": "^6.12.2",
    "lint-staged": "^17.0.4",
    "oxlint": "^1.63.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
