{
  "name": "mediurg",
  "version": "1.0.0",
  "description": "Application PWA hors ligne de pharmacologie d'urgence pour SAUV, SMUR et SAU",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@supabase/supabase-js": "2.110.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "node scripts/check-versions.cjs && vite build",
    "analyze": "cross-env ANALYZE=true vite build && echo Open build/stats.html",
    "preview": "vite preview",
    "check-versions": "node scripts/check-versions.cjs",
    "verify:asset-refs": "node scripts/check-asset-refs.cjs",
    "verify:dead-css": "node scripts/audit-dead-css.cjs",
    "verify:source-size": "node scripts/check-source-size.cjs",
    "verify:pwa-offline": "node scripts/verify-pwa-offline.cjs",
    "verify:pwa-offline:browser": "node scripts/verify-pwa-offline-browser.cjs",
    "verify:security": "node scripts/verify-security-config.cjs",
    "verify:bundle-budget": "node scripts/check-bundle-budget.cjs",
    "verify:pwa-manifest": "node scripts/verify-pwa-manifest.cjs",
    "verify:offline-screenshots": "node scripts/check-offline-screenshots.cjs",
    "verify:a11y-keyboard": "node scripts/verify-a11y-keyboard.cjs",
    "verify:e2e-critical": "node scripts/verify-e2e-critical.cjs",
    "verify:perf-runtime": "node scripts/verify-runtime-performance.cjs",
    "report:data": "node scripts/report-clinical-data.mjs",
    "report:data:strict": "node scripts/report-clinical-data.mjs --strict",
    "release:check": "node scripts/release-check.cjs",
    "lint": "eslint src",
    "lint:fast": "oxlint src",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css}\" \"*.{js,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css}\" \"*.{js,json,html}\"",
    "verify": "npm run typecheck && npm run lint && npm run knip && npm run verify:asset-refs && npm run verify:dead-css && npm run verify:source-size && npm test",
    "test": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest",
    "test:coverage": "cross-env NODE_OPTIONS=--no-experimental-webstorage vitest run --coverage",
    "generate-pwa-assets": "pwa-assets-generator",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint",
      "prettier --write"
    ],
    "*.{css,html,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "knip": "^6.26.0",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
